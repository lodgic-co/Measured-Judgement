{
  "name": "measured-judgement",
  "version": "1.0.0",
  "description": "Internal authority service \u2014 identity resolution, permission evaluation, and routing directory",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --import ./dist/observability/otel-preload.js dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:check": "redocly lint openapi/openapi.yaml --config openapi/.redocly.yaml",
    "migrate": "node scripts/run-migrate.cjs",
    "migrate:down": "node scripts/run-rollback.cjs",
    "db:seed:dev": "node-pg-migrate up --migrations-dir db/migrations_dev --database-url $DATABASE_URL_DIRECT --migrations-table pgmigrations_measured_judgement_dev",
    "db:create-migration": "node-pg-migrate create --migrations-dir db/migrations",
    "ci": "node scripts/assert-authority-derived-validator-bundles.mjs && node scripts/validate-governance-entrypoint.mjs && node scripts/validate-generated-artifact-ownership.mjs && pnpm typecheck && pnpm lint && pnpm openapi:check && pnpm verify:generated && pnpm migrate && pnpm test && pnpm build",
    "verify:generated": "node scripts/verify-generated-artifacts.cjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@redocly/cli": "^2.30.1",
    "env-schema": "^7.0.0",
    "fastify": "^5.8.5",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "yaml": "2.8.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.0",
    "vite": "7.3.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "overrides": {
      "vite": "7.3.2",
      "protobufjs": "7.5.5",
      "postcss": "8.5.10",
      "fast-xml-parser": "5.7.2",
      "handlebars": "4.7.9",
      "picomatch": "4.0.4",
      "flatted": "3.4.2",
      "brace-expansion@2": "2.0.3",
      "brace-expansion@5": "5.0.5",
      "yaml@1": "1.10.3",
      "yaml@2": "2.8.3"
    }
  }
}
