NODE_ENV=test
PORT=5001
LOG_LEVEL=silent
AUTH0_DOMAIN=test.auth0.com
AUTH0_ISSUER=https://test.auth0.com/
AUTH0_AUDIENCE=https://internal.test.example.com/
AUTH0_ALLOWED_AZP=test-m2m-client
AUTH0_JWKS_URI=https://test.auth0.com/.well-known/jwks.json
DATABASE_URL=postgresql://user:pass@localhost:5432/lodgic_test?schema=measured_judgement
DATABASE_URL_DIRECT=postgresql://user:pass@localhost:5432/lodgic_test
DB_SCHEMA=measured_judgement
DB_POOL_SIZE=2
DB_CONNECTION_TIMEOUT_MS=3000
DB_IDLE_TIMEOUT_MS=5000
SYSTEM_DEFAULT_LANGUAGE=en
SYSTEM_DEFAULT_LOCALE=en-AU
SYSTEM_DEFAULT_TIMEZONE=UTC
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=measured-judgement-test
INTERNAL_SERVICE_SECRET=test-internal-secret
