# measured-judgement environment variables

PORT=5001
NODE_ENV=development
LOG_LEVEL=info

# Auth0 — M2M token validation
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_AUDIENCE=https://internal.your-domain.com/
# Comma-separated list of allowed Auth0 client IDs (azp claim).
# Use a single value for one client or a comma-separated list for multiple:
#   AUTH0_ALLOWED_AZP=client-id-a,client-id-b
AUTH0_ALLOWED_AZP=polite-intervention-m2m-client-id
AUTH0_JWKS_URI=https://your-tenant.auth0.com/.well-known/jwks.json

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/lodgic_dev?schema=measured_judgement
DATABASE_URL_DIRECT=postgresql://user:pass@localhost:5432/lodgic_dev
DB_SCHEMA=measured_judgement
DB_POOL_SIZE=5
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=10000

# System locale defaults (used when user preferences are null)
SYSTEM_DEFAULT_LANGUAGE=en
SYSTEM_DEFAULT_LOCALE=en-AU
SYSTEM_DEFAULT_TIMEZONE=UTC

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=measured-judgement
